{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "eql-loot-filter-manager",
  "version": "0.1.1",
  "identifier": "com.terry.eql-loot-filter-manager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "eql-loot-filter-manager",
        "width": 1200,
        "height": 600,
        "backgroundColor": "#0f172a"
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "items_database.sqlite"
    ]
  }
}
